{
    "name": "@tryforge/forge.db",
    "version": "2.1.1",
    "description": "Easy to use database for ForgeScript.",
    "types": "dist/index.d.ts",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "check": "biome check . && tsc --noEmit",
        "format": "biome format --write .",
        "lint": "biome lint .",
        "lint:fix": "biome check --write .",
        "docgen": "tsc && typedoc src/index.ts && node dist/docgen",
        "commit": "npm run docgen && node dist/commit",
        "test": "tsc && node dist/__tests__/"
    },
    "keywords": [
        "bdfd",
        "aoi.js",
        "aoi",
        "dbd",
        "dbd.ts",
        "dbd.js",
        "easy",
        "fast",
        "efficient",
        "bdscript",
        "database",
        "db"
    ],
    "author": "aggelos007",
    "license": "GPL-3.0",
    "devDependencies": {
        "@biomejs/biome": "^2.5.1",
        "@tryforge/forgescript": "^2.5.0",
        "@types/node": "^20.5.7",
        "discord.js": "^14.23.2",
        "mongodb": "^6.19.0",
        "sqlite3": "^5.1.7",
        "typedoc": "^0.25.0",
        "typescript": "^5.2.2"
    },
    "directories": {
        "doc": "docs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tryforge/ForgeDB.git"
    },
    "bugs": {
        "url": "https://github.com/tryforge/ForgeDB/issues"
    },
    "homepage": "https://github.com/tryforge/ForgeDB#readme",
    "engines": {
        "node": ">=16.11.0"
    },
    "dependencies": {
        "tiny-typed-emitter": "^2.1.0",
        "typeorm": "^0.3.26"
    },
    "peerDependencies": {
        "better-sqlite3": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0 || ^12.0.0",
        "sqlite3": "^5.0.3"
    },
    "peerDependenciesMeta": {
        "better-sqlite3": {
            "optional": true
        },
        "sqlite3": {
            "optional": true
        }
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "sqlite3",
            "better-sqlite3"
        ]
    }
}
